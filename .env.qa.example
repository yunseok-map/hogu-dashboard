# QA(로컬 개발) 환경 — 기본값. 실행: `node server.js`  또는  `HOGU_ENV=qa node server.js`
# 복사해서 `.env.qa`로 저장(‑ gitignore됨). QA는 방어계층 OFF(무제한).
HOGU_ENV=qa
PORT=3311

# QA 데이터는 기본 ./data. 운영과 확실히 분리하려면 주석 해제:
# HOGU_DATA_DIR=./data-qa

# 주기 자동수집(딜/관심상품): 분 단위. QA는 보통 off.
# HOGU_REFRESH_MIN=0

# 네이버 쇼핑 API(선택)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
