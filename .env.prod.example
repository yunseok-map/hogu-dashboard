# 운영(배포) 환경 — 실행: `HOGU_ENV=prod node server.js`
# 복사해서 `.env.prod`로 저장(‑ gitignore됨). prod에서만 방어계층이 켜진다.
HOGU_ENV=prod
PORT=3311

# QA와 분리된 데이터 저장소(상대경로는 실행 위치 기준)
HOGU_DATA_DIR=./data-prod

# 관리자 토큰(필수) — 관심상품·딜 강제갱신·기록삭제 등 쓰기 보호.
# 길고 무작위인 값으로. 미설정 시 관리 엔드포인트는 잠긴다(fail-closed).
HOGU_ADMIN_TOKEN=change-me-to-a-long-random-string

# 방어 튜닝(선택)
HOGU_RATE_MAX=8            # IP당 분석 허용 횟수
HOGU_RATE_WINDOW_MS=300000 # 레이트리밋 창(ms, 기본 5분)
HOGU_CONCURRENCY=2         # 전역 동시 크롤 상한

# 크롤 허용 쇼핑몰 도메인(CSV, 선택). 미설정 시 내장 기본 목록 사용.
# HOGU_ALLOWED_HOSTS=coupang.com,11st.co.kr,gmarket.co.kr,auction.co.kr,ssg.com,danawa.com,naver.com

# 주기 자동수집(딜 공홈크롤 + 관심상품 재수집): 분 단위. 배포엔 켜두는 걸 권장.
HOGU_REFRESH_MIN=180

# 네이버 쇼핑 API(선택)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
